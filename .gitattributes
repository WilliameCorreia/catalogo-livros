# Normaliza todos os arquivos de texto para LF no repositório
* text=auto eol=lf

# Força LF explicitamente para código-fonte
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.env*  text eol=lf
*.sql   text eol=lf
*.prisma text eol=lf
Dockerfile text eol=lf

# Binários — sem conversão
*.png   binary
*.jpg   binary
*.ico   binary
*.svg   binary
